---
import '../assets/styles/global.css'
import cell_tower from "../assets/images/cell_tower.webp"

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	ogImage?: string;
	canonicalUrl?: string;
}

const {
	title = "AlsaMesh - Réseau Mesh Meshtastic en Alsace",
	description = "Découvrez AlsaMesh, le réseau mesh Meshtastic communautaire d'Alsace. Communication LoRa longue portée, libre et résiliente sur 868MHz. Rejoignez-nous !",
	keywords = "meshtastic, mesh, alsace, lora, 868mhz, réseau, communication, open-source, communauté",
	ogImage = cell_tower.src,
	canonicalUrl = Astro.url.href,
} = Astro.props;
---
<!doctype html>
<html lang="fr" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={cell_tower.src} />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Essentials -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="sitemap" href="/sitemap-index.xml" />

		<!-- Open Graph (Facebook, LinkedIn) -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="AlsaMesh" />
		<meta property="og:locale" content="fr_FR" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Additional SEO -->
		<meta name="robots" content="index, follow" />
		<meta name="author" content="AlsaMesh Community" />
		<meta name="theme-color" content="#10b981" />
	</head>
	<body class="bg-neutral-950">
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
