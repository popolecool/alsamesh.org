---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
    <Header />

    <section class="w-full px-4 pb-8">
        <div class="mx-auto w-full max-w-7xl">
            <div class="mb-4">
                <h1 class="text-xl md:text-3xl font-bold text-white">Carte</h1>
                <p class="text-gray-400">Visualisation de la carte Meshtastic</p>
            </div>

            <div class="w-full overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900">
                <iframe
                    src="https://carte.alsamesh.org/?theme=dark&hide-title=true"
                    title="Carte"
                    class="h-[75vh] w-full"
                    loading="lazy"
                ></iframe>
            </div>
        </div>
    </section>

    <Footer />
</Layout>