---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_CONFIG } from '../config/site';

const title = `Carte - ${SITE_CONFIG.ogSiteName}`;
const description = `Découvrez la couverture du réseau mesh Meshtastic en Alsace via notre carte interactive.`;
---

<Layout title={title} description={description}>
    <Header />
    <main>
        <section class="w-full px-4 pb-8">
            <div class="mx-auto w-full max-w-7xl">
                <div class="mb-4">
                    <h1 class="text-xl md:text-3xl font-bold text-white">Carte</h1>
                    <p class="text-gray-400">Visualisation de la carte Meshtastic</p>
                </div>

                <div class="w-full overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900">
                    <iframe
                        src={SITE_CONFIG.mapUrl}
                        title="Carte"
                        class="h-[75vh] w-full"
                        loading="lazy"
                    ></iframe>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>